# KIRAPAY API Key (required)
# Get from https://dashboard.kira-pay.com
KIRAPAY_API_KEY=your_kirapay_api_key_here

# Server Port (optional, default: 3000)
PORT=3000

# Database path (optional)
DATABASE_PATH=./data/kirapay.db

# KIRAPAY API URL (optional, default: https://api.kira-pay.com)
KIRAPAY_BASE_URL=https://api.kira-pay.com
